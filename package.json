{
  "name": "aiagent",
  "private": true,
  "packageManager": "pnpm@9.15.3",
  "scripts": {
    "dev": "pnpm --filter @aiagent/cli dev",
    "build": "pnpm -r build",
    "typecheck": "tsc -b",
    "lint": "eslint \"packages/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\"",
    "lint:fix": "eslint \"packages/**/*.{ts,tsx}\" \"apps/**/*.{ts,tsx}\" --fix",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.6.0",
    "concurrently": "^9.0.0"
  }
}
